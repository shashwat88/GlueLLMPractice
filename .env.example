# LLM provider key (example uses OpenAI-backed GlueLLM)
OPENAI_API_KEY=

# Tool API/user-agent settings
GLUELLM_EDGAR_USER_AGENT=gluellm-interview (contact: your-email@example.com)
GLUELLM_LOG_DIR=/app/logs
EODHD_API_KEY=
WIKIPEDIA_USER_AGENT=gluellm-interview (contact: your-email@example.com)

# Optional logging configuration
PROJECT_LOG_CONSOLE_OUTPUT=true
PROJECT_LOG_LEVEL=INFO
PROJECT_LOG_FILE_LEVEL=DEBUG
PROJECT_LOG_DIR=logs
PROJECT_LOG_FILE_NAME=gluellm_practice.log
PROJECT_LOG_JSON_FORMAT=false
PROJECT_LOG_MAX_BYTES=10485760
PROJECT_LOG_BACKUP_COUNT=5
PROJECT_DISABLE_LOGGING=false
